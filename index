  display: flex;
  align-items: center;
  gap: 12px;
  transition: transform 0.12s, opacity 0.12s;
  box-shadow: 0 8px 32px var(--accent-glow), 0 2px 8px rgba(0,0,0,0.4);
  position: relative;
  overflow: hidden;
}

.btn-locate::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.btn-locate:active { transform: scale(0.98); opacity: 0.9; }

.btn-icon {
  width: 36px; height: 36px;
  background: rgba(255,255,255,0.15);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.btn-text { flex: 1; text-align: left; line-height: 1.2; }
.btn-text strong { display: block; font-size: 0.95rem; }
.btn-text span { font-size: 0.75rem; opacity: 0.8; font-weight: 300; }

.btn-arrow {
  font-size: 1.1rem;
  opacity: 0.8;
}

.btn-locate.loading { cursor: default; opacity: 0.8; }
.spinner {
  width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: none;
}
.btn-locate.loading .spinner { display: block; }
.btn-locate.loading .btn-arrow { display: none; }

@keyframes spin { to { transform: rotate(360deg); } }

/* ── FILTERS ── */
.filter-section {
