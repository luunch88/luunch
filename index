<script>

// ── State ──
let allPlaces = [];
let activeFilter = 'alla';
let userLat = null, userLon = null;
let isLunchTime = false;

// ── Clock & lunch indicator ──
function updateClock() {
  const now = new Date();
  const h = now.getHours();
  const m = String(now.getMinutes()).padStart(2,'0');
  document.getElementById('timePill').textContent = `${h}:${m}`;
  isLunchTime = h >= 11 && h < 14;
  const dot = document.getElementById('lunchDot');
  dot.className = isLunchTime ? 'lunch-indicator' : 'lunch-indicator off';
  document.querySelector('.hero-tag').textContent = isLunchTime
    ? '🟢 Lunch pågår nu'
    : (h < 11 ? '⏳ Lunch om ' + (11-h) + ' timmar' : '✅ Lunch avslutad');
}
updateClock();
setInterval(updateClock, 30000);

// ── Toast ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

// ── Status ──
function setStatus(msg, state='idle') {
  document.getElementById('statusText').textContent = msg;
  const dot = document.getElementById('statusDot');
  dot.className = 'status-dot' + (state === 'live' ? ' live' : state === 'error' ? ' error' : '');
}

// ── Error ──
function showError(msg) {
  const b = document.getElementById('errorBox');
  b.textContent = msg;
  b.classList.add('show');
}
function hideError() {
  document.getElementById('errorBox').classList.remove('show');
}

// ── Haversine distance ──
function haversine(lat1, lon1, lat2, lon2) {
  const R = 6371000;
  const dLat = (lat2-lat1)*Math.PI/180;
  const dLon = (lon2-lon1)*Math.PI/180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function distLabel(m) {
  return m < 1000 ? Math.round(m/10)*10 + ' m' : (m/1000).toFixed(1) + ' km';
}

// ── Emoji by type ──
function placeEmoji(types, name) {
  const n = (name||'').toLowerCase();
  if (/sushi|japan|maki/i.test(n)) return '🍣';
  if (/pizza|pizzeria/i.test(n)) return '🍕';
  if (/burger|hamburgare/i.test(n)) return '🍔';
  if (/thai|saigon|vietnam|wok|noodle|ramen/i.test(n)) return '🍜';
  if (/india|curry|tandoor/i.test(n)) return '🫓';
  if (/sallad|vegansk|vegan|bowl/i.test(n)) return '🥗';
  if (types?.includes('cafe') || types?.includes('bakery')) return '☕';
  if (types?.includes('bar')) return '🍺';
  return '🍽️';
}

// ── Price label ──
function priceLabel(level) {
  if (!level) return '';
  const labels = ['', '€', '€€', '€€€', '€€€€'];
  return labels[level] || '';
}

// ── Category filter ──
const filterRegex = {
  asiatiskt: /kines|japan|asian|wok|dim\s*sum|thai|vietnam|korea|noodle|ramen|kinesisk/i,
  burgare: /burger|hamburgare|grill|bbq/i,
  pizza: /pizza|pizzeria/i,
  sushi: /sushi|maki|japan/i,
  vegetariskt: /vegansk|vegetarisk|vegan|sallad|salad|green|bowl/i,
  thai: /thai|bangkok/i,
  indiskt: /india|indisk|curry|tandoor|masala/i,
};

function matchesFilter(place, filter) {
  if (filter === 'alla') return true;
  const name = (place.name || '').toLowerCase();
  const types = (place.types || []).join(' ');
  const cuisine = name + ' ' + types;
  return filterRegex[filter]?.test(cuisine) ?? true;
}

// ── Fetch nearby via Google Places API ──
async function fetchNearbyPlaces(lat, lon) {
  const radius = 800;
  const url = `https://maps.googleapis.com/maps/api/place/nearbysearch/json?location=${lat},${lon}&radius=${radius}&type=restaurant&key=${GOOGLE_API_KEY}`;
  // NOTE: Direct API call works for testing. For production, proxy through backend to protect key.
  const res = await fetch(url);
  if (!res.ok) throw new Error('API-fel');
  const data = await res.json();
  if (data.status === 'REQUEST_DENIED') throw new Error('API-nyckel ogiltig eller saknar behörighet');
  return data.results || [];
}

// ── Photo URL ──
function photoUrl(photoRef) {
  if (!photoRef) return null;
  return `https://maps.googleapis.com/maps/api/place/photo?maxwidth=600&photoreference=${photoRef}&key=${GOOGLE_API_KEY}`;
}

// ── Render cards ──
function renderCards(places) {
  const container = document.getElementById('results');
  const header = document.getElementById('sectionHeader');
  const count = document.getElementById('sectionCount');
  container.innerHTML = '';

  const filtered = activeFilter === 'alla'
    ? places
    : places.filter(p => matchesFilter(p, activeFilter));

  if (filtered.length === 0) {
    header.style.display = 'none';
    container.innerHTML = `
      <div class="empty-state">
        <div class="empty-emoji">😔</div>
        <h3>Inga träffar</h3>
        <p>Inga ställen matchade filtret.<br>Prova ett annat alternativ.</p>
      </div>`;
    return;
  }

  header.style.display = 'flex';
  count.textContent = filtered.length + ' ställen';

  filtered.forEach(place => {
    const dist = (userLat && place.geometry)
      ? haversine(userLat, userLon, place.geometry.location.lat, place.geometry.location.lng)
      : null;

    const openNow = place.opening_hours?.open_now;
    const statusClass = openNow === true ? 'open' : openNow === false ? 'closed' : 'unknown';
    const statusText = openNow === true ? '● Öppet nu' : openNow === false ? '● Stängt' : 'Okänt';

    const photo = place.photos?.[0]?.photo_reference;
    const emoji = placeEmoji(place.types, place.name);
    const price = priceLabel(place.price_level);
    const rating = place.rating;
    const ratingCount = place.user_ratings_total;
    const address = place.vicinity || '';
    const mapsUrl = `https://www.google.com/maps/place/?q=place_id:${place.place_id}`;

    // Simulated today's menu (in real version: fetch from your DB or restaurant API)
    const menuItems = [
      'Köttbullar med potatismos & lingon',
      'Grillad lax med dillsås & råris',
      'Pasta Carbonara med parmesan',
      'Kycklingwok med jasminris',
      'Vegetarisk lasagne med sallad',
      'Falafelbowl med hummus & pitabröd',
      'Fläskkarré med äppelkompott',
      null // some places don't have menu listed
    ];
    const todayMenu = place.name.length % 4 === 0 ? null : menuItems[place.name.charCodeAt(0) % menuItems.length];

    // Simulated deals
    const hasDeal = place.name.charCodeAt(1) % 5 === 0;
    const dealText = hasDeal ? '🔥 Lunchdeal 95 kr — inkl. kaffe' : null;

    const card = document.createElement('div');
    card.className = 'card';
    card.onclick = () => window.open(mapsUrl, '_blank');

    card.innerHTML = `
      ${dealText ? `<div class="card-deal">⚡ ${dealText}</div>` : ''}
      ${photo
        ? `<img class="card-photo" src="${photoUrl(photo)}" alt="${place.name}" loading="lazy" onerror="this.style.display='none'">`
        : `<div class="card-photo-placeholder">${emoji}</div>`
      }
      <div class="card-body">
        <div class="card-top">
          <div class="card-name">${place.name}</div>
          ${dist !== null ? `<div class="card-dist">${distLabel(dist)}</div>` : ''}
        </div>
        <div class="card-meta">
          <span class="card-type">${emoji} ${place.types?.[0]?.replace(/_/g,' ') || 'Restaurang'}</span>
          ${rating ? `<span class="card-rating"><span class="star">★</span> ${rating} <span class="rating-count">(${ratingCount})</span></span>` : ''}
          <span class="card-status ${statusClass}">${statusText}</span>
          ${price ? `<span class="price-dots">${price}</span>` : ''}
        </div>
        ${todayMenu ? `
        <div class="card-menu">
          <div class="card-menu-label">Dagens lunch</div>
          <div class="card-menu-text">${todayMenu}</div>
        </div>` : ''}
        <div class="card-footer">
          <div class="card-address">📍 ${address}</div>
          <a href="${mapsUrl}" target="_blank" rel="noopener" class="card-maps-btn" onclick="event.stopPropagation()">
            Vägbeskrivning →
          </a>
        </div>
      </div>
    `;
    container.appendChild(card);
  });

  setStatus(`${filtered.length} ställen hittade nära dig`, 'live');
}

// ── Filter chip ──
function filterChip(el, type) {
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  activeFilter = type;
  if (allPlaces.length > 0) renderCards(allPlaces);
}

// ── Main locate ──
async function locate() {
  const btn = document.getElementById('locateBtn');
  const label = document.getElementById('locateLabel');
  const sub = document.getElementById('locateSub');

  if (!navigator.geolocation) {
    showError('Din webbläsare stöder inte platsinformation.');
    return;
  }

  btn.classList.add('loading');
  label.textContent = 'Hämtar din plats…';
  sub.textContent = 'Aktiverar GPS';
  hideError();
  setStatus('Hämtar din position…');

  navigator.geolocation.getCurrentPosition(async (pos) => {
    userLat = pos.coords.latitude;
    userLon = pos.coords.longitude;

    label.textContent = 'Söker restauranger…';
    sub.textContent = 'Kollar vad som är öppet';
    setStatus('Söker lunchställen nära dig…');

    try {
      const places = await fetchNearbyPlaces(userLat, userLon);

      // Sort by distance
      allPlaces = places
        .map(p => ({
          ...p,
          _dist: p.geometry
            ? haversine(userLat, userLon, p.geometry.location.lat, p.geometry.location.lng)
            : 9999
        }))
        .sort((a, b) => a._dist - b._dist)
        .slice(0, 25);

      if (allPlaces.length === 0) {
        showError('Inga restauranger hittades inom 800 meter. Prova ett annat område.');
        setStatus('Inga resultat', 'error');
      } else {
        renderCards(allPlaces);
        showToast(`${allPlaces.length} lunchställen nära dig! 🍽️`);
      }

    } catch(err) {
      console.error(err);
      showError(`Kunde inte hämta restauranger: ${err.message}. Kontrollera att API-nyckeln är rätt inlagd.`);
      setStatus('Fel vid hämtning', 'error');
    }

    btn.classList.remove('loading');
    label.textContent = 'Sök igen';
    sub.textContent = 'Uppdatera resultat';

  }, (err) => {
    btn.classList.remove('loading');
    label.textContent = 'Hitta lunch nära mig';
    sub.textContent = 'Öppna restauranger inom gångavstånd';
    let msg = 'Kunde inte hämta din plats.';
    if (err.code === 1) msg = 'Platsbehörighet nekad. Tillåt platsdelning i webbläsaren och försök igen.';
    if (err.code === 3) msg = 'Timeout — försök igen.';
    showError(msg);
    setStatus('Platsbehörighet nekad', 'error');
  }, {
    enableHighAccuracy: true,
    timeout: 10000,
    maximumAge: 120000
  });
}
</script>
