  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--ink2);
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 5px 11px;
  border-radius: 99px;
}

.lunch-indicator {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2s infinite;
}
.lunch-indicator.off { background: var(--ink2); animation: none; }

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

/* ── HERO ── */
.hero {
  padding: 32px 20px 24px;
  position: relative;
  z-index: 1;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 14px;
}
.hero-tag::before {
  content: '';
  display: block;
  width: 20px;
  height: 1.5px;
  background: var(--accent);
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-weight: 900;
  font-size: clamp(2.4rem, 9vw, 3.2rem);
  line-height: 1.0;
  letter-spacing: -0.04em;
  margin-bottom: 14px;
}

.hero h1 em {
  font-style: italic;
  color: var(--accent);
}

.hero p {
  color: var(--ink2);
  font-size: 0.9rem;
  font-weight: 300;
  line-height: 1.6;
  max-width: 300px;
}

/* ── LOCATE BUTTON ── */
.locate-wrap {
  padding: 0 20px 20px;
  position: relative;
  z-index: 1;
}

.btn-locate {
  width: 100%;
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 18px 22px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
