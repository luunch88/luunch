.card:nth-child(4) { animation-delay: 0.18s; }
.card:nth-child(5) { animation-delay: 0.24s; }
.card:nth-child(6) { animation-delay: 0.30s; }
.card:nth-child(7) { animation-delay: 0.36s; }
.card:nth-child(8) { animation-delay: 0.42s; }

@keyframes fadeUp {
